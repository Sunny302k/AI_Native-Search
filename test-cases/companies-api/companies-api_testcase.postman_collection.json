{
  "info": {
    "_postman_id": "4951f8d4-0fbe-4ce2-bc80-28f35a0dc141",
    "name": "Companies API - Get Company List",
    "description": "Tự động sinh từ test-cases/companies-api/companies-api_testcase.csv. Mỗi request tương ứng 1 test case (TC01-TC08).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "TC01 - Lấy danh sách company thành công với token hợp lệ",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "accept", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/companies",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "companies"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "// TODO: cần confirm tên field chính xác (total/rows hoặc data/meta) trước khi assert schema chi tiết"
            ]
          }
        }
      ]
    },
    {
