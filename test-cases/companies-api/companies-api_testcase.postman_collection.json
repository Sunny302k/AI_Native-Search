    {
      "name": "TC07 - Gửi token không hợp lệ hoặc bị chỉnh sửa",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tampered_token}}" },
          { "key": "accept", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/companies",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "companies"]
        },
        "description": "tampered_token được tự sinh ở Pre-request Script bằng cách phá signature của {{token}}. Cần điền {{token}} hợp lệ trước khi chạy."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Tạo token không hợp lệ bằng cách phá signature của token gốc",
              "// Dùng pm.variables.get để tự ưu tiên Environment trước Collection",
              "const original = pm.variables.get(\"token\") || \"\";",
              "pm.collectionVariables.set(\"tampered_token\", original.slice(0, -5) + \"XXXXX\");"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 401\", function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "TC08 - Gửi token đã hết hạn",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{expired_token}}" },
          { "key": "accept", "value": "application/json" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/companies",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "companies"]
        },
        "description": "QA cần tự cung cấp 1 JWT hợp lệ nhưng đã hết hạn (claim exp < hiện tại) vào biến môi trường expired_token trước khi chạy test case này. Không thể tự sinh vì cần chữ ký hợp lệ từ server."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 401\", function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    }
